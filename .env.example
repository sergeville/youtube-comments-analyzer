# youtube-comments-analyzer — Neo4j connection (copy to .env; .env is gitignored)
# Never commit real credentials. For local Docker Neo4j, http://localhost:7474 is fine.
# A non-localhost NEO4J_URL MUST use https:// (TLS enforced by the import/verify scripts).

# Neo4j HTTP endpoint. Local Docker default:
NEO4J_URL=http://localhost:7474

# Database name (Neo4j 5 community default is "neo4j"):
NEO4J_DATABASE=neo4j

# Credentials. For local Docker, user is "neo4j" and password matches NEO4J_AUTH in docker-compose.yml:
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

YCA_OLLAMA_MODEL=gemma4:latest

# yt-dlp authentication (optional). YouTube may bot-gate unauthenticated requests
# ("Sign in to confirm you're not a bot"). Set ONE of these to pass cookies to every
# yt-dlp call (transcript, document, comments, channel). yt-dlp also needs a JS runtime
# on PATH — install deno (`brew install deno`).
#
# Robust: export a Netscape cookies.txt (e.g. the "Get cookies.txt LOCALLY" browser
# extension, logged into youtube.com) and point to it:
# YCA_YTDLP_COOKIES=/absolute/path/to/youtube-cookies.txt
#
# Or read cookies straight from a browser (needs decrypt access; Safari needs the runner
# to have Full Disk Access; macOS Chrome cookies often won't decrypt):
# YCA_YTDLP_COOKIES_FROM_BROWSER=safari
#
# Optional: force a player client if the default gets gated:
# YCA_YTDLP_PLAYER_CLIENT=web_safari,web