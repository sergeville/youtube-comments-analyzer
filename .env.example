# youtube-comments-analyzer — Neo4j connection (copy to .env; .env is gitignored)
# Never commit real credentials. For local Docker Neo4j, http://localhost:7474 is fine.
# A non-localhost NEO4J_URL MUST use https:// (TLS enforced by the import/verify scripts).

# Neo4j HTTP endpoint. Local Docker default:
NEO4J_URL=http://localhost:7474

# Database name (Neo4j 5 community default is "neo4j"):
NEO4J_DATABASE=neo4j

# Credentials. For local Docker, user is "neo4j" and password matches NEO4J_AUTH in docker-compose.yml:
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
